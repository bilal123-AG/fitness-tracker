page {
  --bg: #0d0d0d;
  --surface: #181818;
  --border: #282828;
  --accent: #4ade80;
  --accent-dim: #22c55e;
  --text: #eee;
  --text-dim: #777;
  --danger: #ef4444;
  --warning: #f59e0b;
  --radius: 14rpx;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  min-height: 100vh;
}
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 20rpx 36rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: 600;
  border: none; transition: all 0.15s;
}
.btn-primary { background: var(--accent); color: #000; }
.btn-primary-big { background: var(--accent); color: #000; padding: 30rpx 60rpx; font-size: 34rpx; border-radius: 24rpx; }
.btn-outline { background: transparent; color: var(--text-dim); border: 2rpx solid var(--border); }
.btn-danger { background: var(--danger); color: #fff; }
.btn-sm { padding: 14rpx 28rpx; font-size: 24rpx; }
.btn:active { opacity: 0.7; }
.btn:disabled { opacity: 0.35; }

.card {
  background: var(--surface); border: 2rpx solid var(--border);
  border-radius: var(--radius); padding: 32rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 20rpx; }