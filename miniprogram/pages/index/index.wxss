.home { padding: 40rpx 32rpx; display: flex; flex-direction: column; gap: 32rpx; padding-bottom: 120rpx; }
.hero { display: flex; flex-direction: column; gap: 8rpx; }
.greeting { font-size: 44rpx; font-weight: 700; }
.subtitle { font-size: 26rpx; color: var(--text-dim); }
.status-card {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--accent-dim); border-radius: 24rpx; padding: 28rpx 32rpx;
  color: #000;
}
.status-card.untrained { background: var(--surface); color: var(--text); border: 2rpx solid var(--border); }
.status-left { display: flex; align-items: center; gap: 20rpx; }
.status-icon { font-size: 48rpx; }
.status-title { font-size: 28rpx; font-weight: 700; display: block; }
.status-sub { font-size: 22rpx; opacity: 0.7; }
.week-badge { font-size: 24rpx; font-weight: 600; background: rgba(0,0,0,0.15); padding: 10rpx 20rpx; border-radius: 30rpx; }
.untrained .week-badge { background: var(--border); }
.start-btn { width: 100%; margin-top: 10rpx; }
.plan-items { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 20rpx; }
.plan-row { display: flex; align-items: center; gap: 20rpx; background: var(--surface); border-radius: var(--radius); padding: 20rpx 24rpx; }
.plan-order { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; background: var(--accent); color: #000; border-radius: 50%; font-size: 24rpx; font-weight: 700; flex-shrink: 0; }
.plan-info { flex: 1; }
.plan-move { font-size: 28rpx; font-weight: 600; display: block; }
.plan-target { font-size: 22rpx; color: var(--text-dim); }
.stat-row { display: flex; gap: 20rpx; }
.stat-item { flex: 1; background: var(--surface); border: 2rpx solid var(--border); border-radius: var(--radius); padding: 28rpx 16rpx; text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 700; display: block; }
.stat-lbl { font-size: 22rpx; color: var(--text-dim); }
.offline-bar {
  background: #f59e0b;
  color: #000;
  text-align: center;
  padding: 12rpx 20rpx;
  border-radius: var(--radius);
  margin-bottom: 8rpx;
}
.offline-text { font-size: 24rpx; font-weight: 500; }