.login-page { min-height: 100vh; display: flex; flex-direction: column; padding: 120rpx 48rpx 60rpx; }
.login-hero { display: flex; flex-direction: column; align-items: center; gap: 16rpx; margin-bottom: 80rpx; }
.login-icon { font-size: 100rpx; }
.login-title { font-size: 56rpx; font-weight: 700; }
.login-sub { font-size: 28rpx; color: var(--text-dim); }
.login-form { display: flex; flex-direction: column; gap: 32rpx; }
.lf-field { display: flex; flex-direction: column; gap: 14rpx; }
.lf-label { font-size: 26rpx; color: var(--text-dim); padding-left: 8rpx; }
.lf-input { background: var(--surface); border: 2rpx solid var(--border); border-radius: 24rpx; padding: 28rpx 32rpx; color: var(--text); font-size: 30rpx; }
.login-btn { width: 100%; background: #07c160 !important; color: #fff !important; }
.skip-btn { width: 100%; background: transparent !important; color: var(--text-dim) !important; }
.login-footer { margin-top: auto; text-align: center; }
.lf-tos { font-size: 22rpx; color: var(--text-dim); }