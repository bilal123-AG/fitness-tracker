<view class="movements-page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索动作..." value="{{keyword}}" bindinput="onSearch" />
  </view>
  <view class="filter-row">
    <text class="filter-item {{!selCat?'active':''}}" bindtap="filterCat" data-cat="">全部</text>
    <text class="filter-item {{selCat==='Chest'?'active':''}}" bindtap="filterCat" data-cat="Chest">胸</text>
    <text class="filter-item {{selCat==='Back'?'active':''}}" bindtap="filterCat" data-cat="Back">背</text>
    <text class="filter-item {{selCat==='Legs'?'active':''}}" bindtap="filterCat" data-cat="Legs">腿</text>
    <text class="filter-item {{selCat==='Shoulders'?'active':''}}" bindtap="filterCat" data-cat="Shoulders">肩</text>
    <text class="filter-item {{selCat==='Arms'?'active':''}}" bindtap="filterCat" data-cat="Arms">手臂</text>
    <text class="filter-item {{selCat==='Core'?'active':''}}" bindtap="filterCat" data-cat="Core">核心</text>
  </view>
  <view class="equip-row">
    <text class="filter-item {{!selEquip?'active':''}}" bindtap="filterEquip" data-equip="">全部器械</text>
    <text class="filter-item {{selEquip==='杠铃'?'active':''}}" bindtap="filterEquip" data-equip="杠铃">杠铃</text>
    <text class="filter-item {{selEquip==='哑铃'?'active':''}}" bindtap="filterEquip" data-equip="哑铃">哑铃</text>
    <text class="filter-item {{selEquip==='自重'?'active':''}}" bindtap="filterEquip" data-equip="自重">自重</text>
    <text class="filter-item {{selEquip==='绳索'?'active':''}}" bindtap="filterEquip" data-equip="绳索">绳索</text>
    <text class="filter-item {{selEquip==='器械'?'active':''}}" bindtap="filterEquip" data-equip="器械">器械</text>
  </view>
  <view class="move-list">
    <view class="move-item" wx:for="{{movements}}" wx:key="id" bindtap="selectMove" data-id="{{item.id}}" data-name="{{item.name}}">
      <text class="move-cat">{{item.category}}</text>
      <view class="move-content">
        <text class="move-name">{{item.name}}</text>
        <text class="move-equip">{{item.equipment}} · {{item.default_sets}}组×{{item.default_reps}}次</text>
      </view>
    </view>
  </view>
</view>