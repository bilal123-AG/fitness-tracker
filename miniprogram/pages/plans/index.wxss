.plans-page { padding: 40rpx 32rpx; padding-bottom: 120rpx; }
.plan-list { display: flex; flex-direction: column; gap: 24rpx; }
.plan-card { background: var(--surface); border: 2rpx solid var(--border); border-radius: var(--radius); padding: 28rpx; }
.plan-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.plan-card-name { font-size: 32rpx; font-weight: 700; }
.plan-card-day { font-size: 24rpx; color: var(--accent); }
.plan-moves { display: flex; flex-direction: column; gap: 12rpx; }
.pm-item { display: flex; align-items: center; gap: 16rpx; padding: 12rpx 16rpx; background: var(--bg); border-radius: 10rpx; }
.pm-order { width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center; background: var(--accent); color: #000; border-radius: 50%; font-size: 20rpx; font-weight: 700; flex-shrink: 0; }
.pm-name { flex: 1; font-size: 26rpx; }
.pm-info { font-size: 22rpx; color: var(--text-dim); flex-shrink: 0; }
.plan-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.pa-btn { font-size: 26rpx; color: var(--accent); padding: 12rpx 24rpx; border-radius: 12rpx; background: rgba(74,222,128,0.1); }
.empty-state { text-align: center; padding: 80rpx 0; color: var(--text-dim); }
.quick-cats { display: flex; flex-wrap: wrap; gap: 16rpx; }
.qc-item { padding: 18rpx 30rpx; background: var(--surface); border: 2rpx solid var(--border); border-radius: 20rpx; font-size: 26rpx; color: var(--text); }
.qc-item:active { background: var(--accent); color: #000; }