.training { padding: 40rpx 32rpx; min-height: 100vh; display: flex; flex-direction: column; gap: 40rpx; padding-bottom: 120rpx; }
.train-header { display: flex; justify-content: space-between; align-items: center; }
.train-timer { font-size: 48rpx; font-weight: 700; font-variant-numeric: tabular-nums; }
.train-session { font-size: 24rpx; color: var(--accent); background: rgba(74,222,128,0.15); padding: 8rpx 20rpx; border-radius: 20rpx; }
.train-main { display: flex; flex-direction: column; align-items: center; gap: 36rpx; }
.move-name { font-size: 52rpx; font-weight: 700; text-align: center; }
.move-equip { font-size: 24rpx; color: var(--text-dim); }
.group-progress { font-size: 32rpx; font-weight: 600; color: var(--accent); }
.input-cards { display: flex; gap: 20rpx; width: 100%; }
.input-card { flex: 1; background: var(--surface); border: 2rpx solid var(--border); border-radius: var(--radius); padding: 28rpx 20rpx; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.input-label { font-size: 24rpx; color: var(--text-dim); }
.input-stepper { display: flex; align-items: center; gap: 16rpx; }
.stepper-btn { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--border); color: var(--text); font-size: 40rpx; display: flex; align-items: center; justify-content: center; border: none; line-height: 72rpx; padding: 0; }
.stepper-val { width: 120rpx; text-align: center; font-size: 44rpx; font-weight: 700; background: transparent; color: var(--text); border: none; }
.quick-weights { display: flex; gap: 12rpx; margin-top: 12rpx; }
.qw-item { font-size: 22rpx; padding: 8rpx 18rpx; border-radius: 16rpx; background: var(--border); color: var(--text-dim); }
.qw-item.active { background: var(--accent); color: #000; }
.record-btn { width: 100%; }
.rest-area { display: flex; flex-direction: column; align-items: center; gap: 16rpx; background: var(--surface); border-radius: var(--radius); padding: 36rpx; width: 100%; }
.rest-label { font-size: 24rpx; color: var(--text-dim); }
.rest-time { font-size: 80rpx; font-weight: 700; color: var(--accent); }
.rest-actions { display: flex; gap: 40rpx; }
.rest-action { font-size: 26rpx; color: var(--accent-dim); padding: 12rpx; }
.upcoming-list { display: flex; flex-direction: column; gap: 16rpx; }
.up-item { display: flex; align-items: center; gap: 20rpx; padding: 16rpx 24rpx; background: var(--surface); border-radius: var(--radius); }
.up-item.done { opacity: 0.4; }
.up-num { width: 48rpx; height: 48rpx; text-align: center; line-height: 48rpx; background: var(--border); border-radius: 50%; font-size: 24rpx; flex-shrink: 0; }
.train-footer { display: flex; gap: 20rpx; margin-top: auto; }
.train-footer .btn { flex: 1; }

.pr-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 200; display: none; flex-direction: column; align-items: center; justify-content: center; gap: 28rpx; }
.pr-overlay.show { display: flex; }
.pr-icon { font-size: 120rpx; }
.pr-title { font-size: 48rpx; font-weight: 700; color: var(--accent); }
.pr-detail { font-size: 28rpx; color: var(--text-dim); }